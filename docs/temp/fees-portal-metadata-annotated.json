                        {
                            "sql": "select smmq.\"name\" as \"queue_name\", coalesce(sum(smm.elapsed_millis), 0) as \"sum_elapsed_millis\" from ss_mq_message_queue smmq left join ss_mq_message smm on smm.mq_message_queue_id = smmq.id where {{dashboardDate[smm.created_at]}} group by smmq.\"name\";", // SQL with variables
                            "datasetName": "total_elapsed_millis_for_database_horiz",
                            "labelColumnName": "queue_name", // X-axis
                            "valueColumnName": "sum_elapsed_millis" // Y-axis
                        }
                    ]
                }
