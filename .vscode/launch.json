{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/rag_ingestion"
        },
        {
            "name": "Python Debugger: ingest_docs.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/rag_ingestion/ingest_docs.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/rag_ingestion",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/rag_ingestion"
            }
        }
    ]
}